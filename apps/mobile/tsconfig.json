{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@theme": [
        "src/theme"
      ],
      "@theme/*": [
        "src/theme/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@features/*": [
        "src/features/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@navigation/*": [
        "src/navigation/*"
      ],
      "@translations/*": [
        "src/translations/*"
      ],
      "@backend/*": [
        "../../packages/backend/convex/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
